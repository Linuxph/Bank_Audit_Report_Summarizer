# ══════════════════════════════════════════════════════════════════
#  BARS — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── AI Service (FastAPI) ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
PDF_WORKERS=4

# ALLOWED_ORIGINS — comma-separated list of allowed frontend URLs
# For production: set to your Vercel URL, e.g. https://bars.vercel.app
# For local dev: leave as * or http://localhost:5173
ALLOWED_ORIGINS=*

# ── Spring Boot Backend ────────────────────────────────────────────
# MongoDB Atlas URI (for production)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/bars_db

# JWT — keep your existing value (base64 encoded, min 32 chars)
JWT_SECRET=VGhpc0lzQVNlY3VyZUFuZEhTZTI1NktleUZvckJhcnNQcm9qZWN0MTIzNDU2Nzg5MA==
JWT_EXPIRATION_MS=86400000

# Render URL of the AI service (used by Spring Boot to call AI)
# In production: https://bars-ai-service.onrender.com
# In local dev: http://localhost:8000
AI_SERVICE_URL=http://localhost:8000

# Cloudinary — your existing credentials
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_FOLDER=bank-audit-reports

# ── Frontend (Vite build-time vars) ───────────────────────────────
# These are injected at BUILD TIME by Vercel.
# Set them in Vercel dashboard → Project → Settings → Environment Variables.

# Spring Boot backend URL (leave empty to use Vercel rewrite rules)
# Example: https://bars-backend.onrender.com
VITE_API_BASE_URL=

# AI service URL (RECOMMENDED: set this to avoid SSE issues through Vercel)
# Example: https://bars-ai-service.onrender.com
VITE_AI_BASE_URL=
